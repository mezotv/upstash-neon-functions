# Neon Postgres connection. Required for the board to show real tickets;
# without it the app falls back to a read-only demo board.
DATABASE_URL="postgres://user:password@host/database?sslmode=require"

# Upstash QStash token. Required to trigger the ticket-triage workflow on new
# tickets and approvals. Without it, tickets are saved but never triaged.
QSTASH_TOKEN=""

# QStash signing keys. Used by @upstash/workflow's serve() to verify incoming
# QStash callbacks to /api/workflows/ticket-triage. Find them in the Upstash
# Console under QStash > Request Builder / Signing Keys.
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# Public URL for QStash to call back into this app.
# In production this can be omitted on Vercel because VERCEL_URL is available.
# For local development, use a tunnel such as ngrok or the Upstash local tunnel.
APP_URL="https://your-public-app-url.example.com"

# Deployed Neon Function endpoint for ticket triage.
TRIAGE_FUNCTION_URL="https://your-triage-function-url.example.com/"
TRIAGE_API_KEY=""
TRIAGE_MODEL="gemini-3-5-flash"

# Neon AI Gateway credentials. `neonctl deploy` provisions these when
# `preview.aiGateway` is enabled in neon.ts.
NEON_AI_GATEWAY_BASE_URL=""
NEON_AI_GATEWAY_TOKEN=""

# Set to "true" only if you want deterministic local triage when AI fails.
ALLOW_TRIAGE_FALLBACK=""

# Browser-facing ticket API endpoint. Set these to the Neon Function URL/key
# when you want DevTools requests to go directly to Neon instead of localhost.
NEXT_PUBLIC_TICKET_API_URL="https://your-triage-function-url.example.com/"
NEXT_PUBLIC_TICKET_API_KEY=""

# Optional shared key for browser calls into this app's API routes.
NEXT_PUBLIC_API_KEY=""
