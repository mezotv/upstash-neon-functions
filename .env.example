# Neon Postgres connection. Required for the board to show real tickets;
# without it the app falls back to a read-only demo board.
DATABASE_URL="postgres://user:password@host/database?sslmode=require"

# Upstash QStash token. Required to trigger the ticket-triage workflow on new
# tickets and approvals. Without it, tickets are saved but never triaged.
QSTASH_TOKEN=""

# QStash signing keys. Used by @upstash/workflow's serve() to verify incoming
# QStash callbacks to /api/workflows/ticket-triage. Find them in the Upstash
# Console under QStash > Request Builder / Signing Keys.
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# Public URL for QStash to call back into this app.
# In production this can be omitted on Vercel because VERCEL_URL is available.
# For local development, use a tunnel such as ngrok or the Upstash local tunnel.
APP_URL="https://your-public-app-url.example.com"
