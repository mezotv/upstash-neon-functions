# Neon Postgres connection. Required for the board to show real tickets;
# without it the app falls back to a read-only demo board.
# Get it from Neon Console > Project > Connection Details.
# Docs: https://neon.com/docs/connect/connect-from-any-app
DATABASE_URL="postgres://user:password@host/database?sslmode=require"

# Upstash QStash token. When set, new tickets and manual triage run through the
# durable ticket-triage workflow before calling the Neon Function.
# Get it from Upstash Console > QStash.
# Docs: https://upstash.com/docs/qstash/quickstarts/vercel-nextjs
QSTASH_TOKEN=""

# QStash signing keys. Used by @upstash/workflow's serve() to verify incoming
# QStash callbacks to /api/workflows/ticket-triage.
# Get them from Upstash Console > QStash > Signing Keys.
# Docs: https://upstash.com/docs/workflow/howto/security
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# Public URL for QStash to call back into this app.
# In production this can be omitted on Vercel because VERCEL_URL is available.
# For local development, use a tunnel such as ngrok or the Upstash local tunnel.
# ngrok quickstart: https://ngrok.com/docs/guides/share-localhost/quickstart
APP_URL="https://your-public-app-url.example.com"

# Deployed Neon Function endpoint for ticket triage.
# Get TRIAGE_FUNCTION_URL from `neonctl function get triage --branch production`
# after `neonctl deploy`. TRIAGE_API_KEY is the shared server-side key you choose.
# Docs: https://neon.com/docs/compute/functions/get-started
TRIAGE_FUNCTION_URL="https://your-triage-function-url.example.com/"
TRIAGE_API_KEY=""

# Neon AI Gateway credentials. `neonctl deploy` provisions these when
# `preview.aiGateway` is enabled in neon.ts.
# Docs: https://neon.com/docs/ai-gateway/get-started
NEON_AI_GATEWAY_BASE_URL=""
NEON_AI_GATEWAY_TOKEN=""
